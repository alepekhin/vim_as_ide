{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://localhost:11434/v1"
            },
            "models": {
                "qwen3.5:9b": {
                    "name": "Qwen 3.5"
                }
            }
        },
        "kimi": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://10.0.0.9:8029/v1"
            },
            "models": {
                "Kimi-K2.6": {
                    "name": "Kimi 2.6"
                }
            }
        }
    },
    "lsp": {
        "jdtls": {
            "disabled": true
        },
        "jls": {
            "command": ["/home/alepekhin/projects/Github/jls/dist/lang_server_linux.sh"],
            "extensions": [".java"]

        }
    }
}



